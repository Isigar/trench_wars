# apps/web/.env.example — Laravel-side env shape. Mirrors the repo-root .env.example.
# Source: .planning/phases/01-foundations/01-04-PLAN.md task 2
APP_NAME=Trenchwars
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=trenchwars
DB_USERNAME=trenchwars
DB_PASSWORD=trenchwars
# PRODUCTION (Railway): the app reads DATABASE_URL (the Railway Postgres plugin
# default) as the canonical connection string when set; otherwise it falls back
# to the split DB_* keys above. On Railway set:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# (DB_URL is also accepted as an alias.) See CONFIGURATION.md §2.

SESSION_DRIVER=redis
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# PRODUCTION (Railway): MUST be FILESYSTEM_DISK=s3 — Railway's container
# filesystem is ephemeral, so `local` loses every uploaded clan logo / avatar /
# article cover on each redeploy. Provide an S3-compatible bucket (AWS S3 /
# Cloudflare R2 / Backblaze B2 / MinIO) via the Railway env group:
#   FILESYSTEM_DISK=s3
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_DEFAULT_REGION=
#   AWS_BUCKET=
#   AWS_ENDPOINT=                       # non-AWS providers only (R2/B2/MinIO)
#   AWS_USE_PATH_STYLE_ENDPOINT=false   # true for MinIO / most non-AWS providers
# See CONFIGURATION.md §3 (Filesystems).
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@trenchwars.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Discord OAuth (D-002) ──────────────────────────────────────────────
# Set these via Railway env group in production.
# For local dev: copy this file to apps/web/.env and fill in real values.
# Discord app: https://discord.com/developers/applications → OAuth2 → Redirects:
#   http://localhost:8000/auth/discord/callback (no trailing slash)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback

# Open Question 1 LOCKED — Phase 7 article publish announce channel
# Single global league channel where ArticleObserver enqueues article_announce
# outbound rows (config/discord.php). Empty disables the announce side-effect.
DISCORD_LEAGUE_ANNOUNCE_CHANNEL_ID=

# ─── Sanctum bot↔web (Phase 5 plan 05-01) ───────────────────────────────
# Personal Access Token issued by Artisan command (lands in plan 05-07).
# T-05-01-02 mitigation: keep this empty in .env.example — never commit a
# token-shaped placeholder (Pitfall 3). Operator mints a token locally and
# pastes the plaintext result here once.
WEB_API_TOKEN=

# Sanctum stateful domain list — left blank so bot/web-nginx hostnames cannot
# accidentally promote token auth into session auth (T-05-01-05 mitigation /
# Pitfall 4). Local dev uses localhost + 127.0.0.1 from the Sanctum default;
# production sets this only if a first-party browser SPA actually needs it.
SANCTUM_STATEFUL_DOMAINS=

# ─── Inertia v2 SSR (Phase 7 plan 07-11 — Open Question 7 LOCKED) ───────
# SSR is ENABLED for v1.0. Off in dev to keep the Vite hot-reload loop tight;
# set INERTIA_SSR_ENABLED=true in the production Railway env group, where a
# dedicated `ssr` service runs `php artisan inertia:start-ssr`. RESEARCH
# Pattern 5 Option B (split service for prod-parity). Pitfall 8 mitigation
# lives in SsrLocaleHonouredTest — locale resolution must reflect into
# <html lang>.
#   PRODUCTION (web env group):
#     INERTIA_SSR_ENABLED=true
#     INERTIA_SSR_URL=http://${{ssr.RAILWAY_PRIVATE_DOMAIN}}:13714
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://ssr:13714
