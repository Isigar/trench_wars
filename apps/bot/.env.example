# Trenchwars Discord bot — environment variables.
#
# Source: .planning/phases/05-discord-bot-v1/05-08-PLAN.md.
# Fetch each value from the Discord Developer Portal:
#   https://discord.com/developers/applications
#
# DISCORD_BOT_TOKEN       — Bot → Reset Token (treat as secret; do NOT commit)
# DISCORD_APPLICATION_ID  — General Information → Application ID (public)
# DISCORD_GUILD_ID        — Server Settings → Widget → Server ID (right-click guild in app with Developer Mode)
#
# IMPORTANT: enable Privileged Gateway Intents → Server Members Intent (ON).
# Without it, guildMemberUpdate events never fire (RESEARCH §Pitfall 6) and
# role-sync reconciliation (plan 05-12) silently breaks.

DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=

# League-wide announce channel (Discord channel ID). Used as the fallback
# destination when the web side writes an outbound row with channel_id=''
# (article/tournament/match-result announces). REQUIRED in practice: tournament
# + bracket announces always write an empty channel_id, so without this the bot
# marks every tournament announce row `failed`. Right-click the channel in the
# Discord app (Developer Mode ON) → Copy Channel ID.
DISCORD_LEAGUE_ANNOUNCE_CHANNEL_ID=

# Public base URL of the Trenchwars web app (no trailing slash), e.g.
# https://trenchwars.example. Used by embeds.ts to build deep links in
# announce embeds (tournaments, brackets). Silently falls back to
# http://localhost when unset, which produces broken links in production.
WEB_URL=

# Trenchwars web API
# WEB_API_URL points at the internal docker network host in compose; in
# production this is the public web service URL (Railway service-to-service).
# WEB_API_TOKEN is the Sanctum personal access token issued via
#   make artisan ARGS="trenchwars:bot:issue-token --name=bot-prod --ttl=90"
# (plan 05-07). Treat as secret; rotate every 90 days.
WEB_API_URL=http://web-nginx
WEB_API_TOKEN=

# Bot internal — outbound worker poll cadence (milliseconds).
OUTBOUND_POLL_INTERVAL_MS=5000
