# Trenchwars CRCON worker — environment variables.
#
# Source: apps/rcon-worker/src/config.ts (loadConfig zod schema).
# All values are validated at boot; missing/invalid values abort startup.

# Shared HMAC secret for worker → web signed requests (≥32 chars).
# MUST match the web service's RCON_HMAC_SECRET. Treat as secret; do NOT commit.
WEB_HMAC_SECRET=

# Internal web API base URL the worker posts events / polls bookings against.
# In docker compose this is the internal nginx host; in production it is the
# Railway web service URL (service-to-service).
WEB_INTERNAL_URL=http://web-nginx

# Node runtime mode: development | test | production.
NODE_ENV=development

# Booking poll cadence (milliseconds). Default 30000.
POLL_INTERVAL_MS=30000

# Redis connection URL. Optional — defaults to redis://redis:6379 when unset.
REDIS_URL=redis://redis:6379

# CRCON WebSocket transport security.
#   true  → dial wss:// (TLS). Use this in production so the RCON bearer token
#           is never sent over the wire in cleartext.
#   false → dial ws:// (plaintext). Only for local CRCON without TLS.
# The CRCON credentials wire contract carries only a bare host (no scheme), so
# the worker cannot infer the scheme from the URL — this flag is the source of
# truth. Defaults to true (secure) when unset.
# NOTE: loopback hosts (localhost / 127.0.0.1 / ::1) always use ws:// regardless
# of this flag, so local dev and the integration test harness work unchanged.
CRCON_WS_SECURE=true
