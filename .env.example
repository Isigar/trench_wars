# Trenchwars — local-dev environment shape.
# Copy to `.env` and fill in real values. NEVER commit .env to git.
# Production secrets live in Railway env groups (D-014).

# ─── App ────────────────────────────────────────────────────────────────
APP_NAME=Trenchwars
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=
# Generate with: docker compose exec web php artisan key:generate

LOG_DEPRECATIONS_CHANNEL=null
# Set to "stack" if you want to surface PHP deprecation warnings (Filament v3 emits some on PHP 8.4)

# ─── Database (Postgres 16) ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=trenchwars
DB_USERNAME=trenchwars
DB_PASSWORD=trenchwars
DB_PORT_HOST=5432
# Host-side port (so `psql -h localhost -p 5432` works from outside the container).

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_PORT_HOST=6379

# ─── Sessions / Cache / Queue (D-001 + research) ────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=43200
# 30 days = 43200 minutes (CONTEXT.md "Remember-me 30 days")
SESSION_SECURE_COOKIE=false
# Set to true ONLY in production; false on http://localhost
SESSION_SAME_SITE=lax
# Lax — works on http://localhost OAuth (research Pitfall 3)

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ─── Filesystem (uploads: clan logos, avatars, article covers) ──────────
# Local dev uses the local disk (Railway prod MUST NOT — its filesystem is
# ephemeral and loses every upload on redeploy).
FILESYSTEM_DISK=local
# PRODUCTION (Railway): set FILESYSTEM_DISK=s3 in the Railway env group and
# provide an S3-compatible bucket (AWS S3 / Cloudflare R2 / Backblaze B2 / MinIO):
#   FILESYSTEM_DISK=s3
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_DEFAULT_REGION=
#   AWS_BUCKET=
#   AWS_ENDPOINT=                       # non-AWS providers only (R2/B2/MinIO)
#   AWS_USE_PATH_STYLE_ENDPOINT=false   # true for MinIO / most non-AWS providers
# See CONFIGURATION.md §3 (Filesystems) for details.

# ─── Discord OAuth (D-002) ──────────────────────────────────────────────
# Create a Discord application at https://discord.com/developers/applications
# OAuth2 → Redirects: register `http://localhost:8000/auth/discord/callback` (LOCAL, exact match).
# Copy CLIENT_ID and CLIENT_SECRET below.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
# Production redirect URI is set in Railway env group; do NOT add a trailing slash anywhere.

# ─── Discord bot (Phase 5; declared now for env-shape parity) ───────────
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ─── Bot ↔ web Sanctum token (Phase 5) ──────────────────────────────────
WEB_API_URL=http://web-nginx
WEB_API_TOKEN=

# ─── RCON worker ↔ web HMAC (Phase 8) ───────────────────────────────────
WEB_HMAC_SECRET=
WEB_INTERNAL_URL=http://web-nginx
